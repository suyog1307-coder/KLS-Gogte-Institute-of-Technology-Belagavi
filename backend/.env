APP_NAME="Transaction Signing System"
DEBUG=false

# ── MySQL connection ──────────────────────────────────────────────────────────
MYSQL_USER=txsign_user
MYSQL_PASSWORD=txsign_pass
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=txsign_db

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_32_BYTES_MIN
KEY_ENCRYPTION_SECRET=CHANGE_ME_KEY_ENCRYPTION_SECRET_32B

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REPLAY_WINDOW_SECONDS=300

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
