APP_NAME="Transaction Signing System"
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql+psycopg2://txsign_user:txsign_pass@localhost:5432/txsign_db

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-jwt-secret-key-min-32-chars-here
KEY_ENCRYPTION_SECRET=your-aes-key-encryption-secret-32b

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REPLAY_WINDOW_SECONDS=300

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
